# =============================================================================
# Root environment file for the monorepo
#
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Used by: apps/api, apps/web, packages/database, packages/services, packages/logger
# Run `./setup.sh` to symlink this file into each app/package directory.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (packages/database)
# -----------------------------------------------------------------------------
# Local Postgres via docker-compose: docker compose up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# -----------------------------------------------------------------------------
# Auth & services (packages/services)
# -----------------------------------------------------------------------------
# Required. Must be at least 32 characters each.
ACCESS_TOKEN_SECRET=change-me-access-token-secret-min-32-chars
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret-min-32-chars

# JWT lifetimes (supports values like 15m, 1h, 7d, 30d)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# Optional Google OAuth (leave blank to disable Google sign-in)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# -----------------------------------------------------------------------------
# API server (apps/api)
# -----------------------------------------------------------------------------
PORT=8000
BASE_URL=http://localhost:8000

# Comma-separated list of allowed browser origins (credentials/cookies enabled)
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Web app (apps/web)
# -----------------------------------------------------------------------------
# tRPC endpoint. Omit to use the relative path "/trpc" (requires a Next.js proxy).
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc

# Set to "true" to skip Next.js env validation during Docker/CI builds
# SKIP_ENV_VALIDATION=true

# -----------------------------------------------------------------------------
# Shared runtime (apps/api, packages/services, packages/logger)
# -----------------------------------------------------------------------------
# Valid values: development | prod  (note: "production" is NOT accepted)
NODE_ENV=development

# Optional log level: error | debug | info
# Defaults to "debug" in development, "error" in prod
# LOGGER_LEVEL=debug
